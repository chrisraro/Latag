{
  "expo": {
    "name": "Latag",
    "slug": "latag",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "latag",
    "userInterfaceStyle": "dark",
    "runtimeVersion": { "policy": "appVersion" },
    "updates": {
      "url": "https://u.expo.dev/465e3d82-c739-4bf8-ab14-8cb7869b4535",
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.chrisraro.latag"
    },
    "android": {
      "package": "com.chrisraro.latag",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-font",
      "expo-sqlite",
      "expo-image",
      [
        "expo-camera",
        {
          "cameraPermission": "Latag uses your camera to photograph items. Photos are compressed and stored on your phone only — never uploaded."
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Latag uses your location only to pin a session on the map. Never tracked, never uploaded."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": ["./assets/sounds/alarm.wav"]
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Latag saves your listing photos to gallery albums you can share.",
          "savePhotosPermission": "Latag saves your listing photos to gallery albums.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "465e3d82-c739-4bf8-ab14-8cb7869b4535"
      }
    },
    "owner": "chrisraro"
  }
}
